# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
ios/
android/

# Keep the local Expo native module's apple sources (autolinking needs the
# podspec + Swift in the EAS clone; the generic `ios/` rule above would
# otherwise strip this committed module directory).
!modules/MoraLiveActivity/ios/
!modules/MoraLiveActivity/ios/**
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo
.vercel

.env
